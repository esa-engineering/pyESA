<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hidden Elements Inspector"
    Height="530" Width="850"
    MinHeight="450" MinWidth="650"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header area -->
        <Border Grid.Row="0"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="5" Padding="10">
            <StackPanel>
                <TextBlock Text="HIDDEN ELEMENTS"
                           FontWeight="Bold" FontSize="12"
                           Foreground="#2D5A8A"/>
                <TextBlock x:Name="lbl_view_name"
                           Text="Current View: -"
                           FontSize="11" Foreground="Gray"
                           Margin="0,3,0,0"/>
                <TextBlock x:Name="lbl_count"
                           Text="Hidden Elements: 0"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#2D5A8A"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- List area -->
        <ListView Grid.Row="1"
                  x:Name="lst_elements"
                  Margin="0,10,0,0"
                  FontSize="11"
                  SelectionMode="Extended">
            <ListView.Resources>
                <!-- Uniform selection color -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D5A8A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2D5A8A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Category"
                                    Width="180"
                                    DisplayMemberBinding="{Binding [Category]}"/>
                    <GridViewColumn Header="Family"
                                    Width="200"
                                    DisplayMemberBinding="{Binding [Family]}"/>
                    <GridViewColumn Header="Type"
                                    Width="200"
                                    DisplayMemberBinding="{Binding [Type]}"/>
                    <GridViewColumn Header="Element ID"
                                    Width="100"
                                    DisplayMemberBinding="{Binding [Id]}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Footer area -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="btn_unhide"
                    Content="Unhide Selected"
                    Background="#D32F2F" Foreground="White"
                    FontWeight="Bold"
                    Width="150" Height="30"
                    Margin="0,0,10,0"
                    ToolTip="Unhide all selected elements in the current view"/>
            <Button x:Name="btn_close"
                    Content="Close"
                    Width="100" Height="30"
                    Padding="10,3" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>
