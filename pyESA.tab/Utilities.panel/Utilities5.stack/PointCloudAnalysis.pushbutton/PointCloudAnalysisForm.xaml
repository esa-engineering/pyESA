<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PointCloud Analysis"
    Height="410" Width="560"
    MinHeight="410" MinWidth="560"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header area -->
        <Border Grid.Row="0"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="5" Padding="10">
            <StackPanel>
                <TextBlock Text="ANALYSIS PARAMETERS"
                           FontWeight="Bold" FontSize="12"
                           Foreground="#2D5A8A"/>
                <TextBlock x:Name="lbl_units"
                           Text="Length values in document units"
                           FontSize="11" Foreground="Gray"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Parameters area -->
        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Grid spacing"
                       VerticalAlignment="Center" FontSize="12"
                       ToolTip="Size of each sampling cell on the face"/>
            <TextBox x:Name="txt_grid" Grid.Row="0" Grid.Column="1"
                     Height="24" Margin="0,4" FontSize="12"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Offset analysis from surface"
                       VerticalAlignment="Center" FontSize="12"
                       ToolTip="Search depth on both sides of the face (along its normal)"/>
            <TextBox x:Name="txt_offset" Grid.Row="1" Grid.Column="1"
                     Height="24" Margin="0,4" FontSize="12"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Tolerance"
                       VerticalAlignment="Center" FontSize="12"
                       ToolTip="Deviation tolerance (+/-): the output reports the percentage of analyzed cloud points within this deviation from the surface"/>
            <TextBox x:Name="txt_tolerance" Grid.Row="2" Grid.Column="1"
                     Height="24" Margin="0,4" FontSize="12"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Sampling quality"
                       VerticalAlignment="Center" FontSize="12"
                       ToolTip="Number of cloud points sampled per cell: fast=10, medium=200, high=1000, all=every point in the cell (may be slow on dense clouds)"/>
            <ComboBox x:Name="cmb_quality" Grid.Row="3" Grid.Column="1"
                      Height="24" Margin="0,4" FontSize="12"
                      VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Color gradient"
                       VerticalAlignment="Center" FontSize="12"
                       ToolTip="Color gradient used for the analysis map, from minimum to maximum deviation. The value range can be customized in Revit under Analysis Display Settings."/>
            <ComboBox x:Name="cmb_gradient" Grid.Row="4" Grid.Column="1"
                      Height="24" Margin="0,4" FontSize="12"
                      VerticalContentAlignment="Center"/>

            <CheckBox x:Name="chk_csv" Grid.Row="5" Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Content="Export CSV of analyzed cells"
                      FontSize="12" Margin="0,10,0,0"
                      ToolTip="Write a CSV file (one row per analyzed cell) to the temp folder and open it in the default application"/>
        </Grid>

        <!-- Footer area -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="btn_ok"
                    Content="Run Analysis"
                    Background="#2D5A8A" Foreground="White"
                    FontWeight="Bold"
                    Width="130" Height="30"
                    Margin="0,0,10,0"/>
            <Button x:Name="btn_cancel"
                    Content="Cancel"
                    Width="100" Height="30"
                    Padding="10,3" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>
