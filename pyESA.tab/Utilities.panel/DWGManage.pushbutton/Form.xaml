<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Imported DWG Manager"
        Height="600" Width="1100"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#2D5A8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3F5F"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3399FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3399FF"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F5F8FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Imported DWG Manager"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#2D5A8A"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

        <!-- Status bar -->
        <TextBlock x:Name="lbl_status" DockPanel.Dock="Top"
                   Text="Loading..."
                   FontSize="11" Foreground="Gray"
                   Margin="0,0,0,8"/>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btn_delete" Content="Delete Selected"
                    Width="150" Height="30"
                    IsEnabled="False"
                    Background="#D32F2F" Foreground="White" FontWeight="Bold"
                    Margin="0,0,10,0"/>
            <Button x:Name="btn_close" Content="Close"
                    Width="100" Height="30"
                    IsCancel="True"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dg_dwgs"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  AlternationCount="2"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Margin="0,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="DWG Name" Binding="{Binding DwgName}" Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="Created By" Binding="{Binding CreatedBy}" Width="Auto" MinWidth="90"/>
                <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="70"/>
                <DataGridTextColumn Header="Workset" Binding="{Binding WorksetName}" Width="Auto" MinWidth="90"/>
                <DataGridTextColumn Header="Hosted Level" Binding="{Binding HostedLevel}" Width="Auto" MinWidth="90"/>
                <DataGridTextColumn Header="Offset from Level (Z)" Binding="{Binding OffsetZ}" Width="Auto" MinWidth="80"/>
                <DataGridTextColumn Header="View Specific" Binding="{Binding ViewSpecific}" Width="80"/>
                <DataGridTextColumn Header="View" Binding="{Binding ViewName}" Width="Auto" MinWidth="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
