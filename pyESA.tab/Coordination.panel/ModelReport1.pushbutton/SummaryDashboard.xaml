<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Report - Summary Dashboard"
        Height="820" Width="1350"
        MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Card KPI -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <!-- Table header -->
        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,6"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <!-- === SEZIONE 1: KPI + TABELLA FILES === -->

            <!-- KPI Cards -->
            <UniformGrid Rows="1" Columns="7" Margin="0,0,0,12">
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="FILE" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_files" Text="0" Style="{StaticResource KpiValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="TOTAL FILE SIZE" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_size" Text="0" Style="{StaticResource KpiValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="WARNINGS" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_warnings" Text="0" Style="{StaticResource KpiValue}" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="PURGEABLE" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_purgeable" Text="0" Style="{StaticResource KpiValue}" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="SHEETS" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_sheets" Text="0" Style="{StaticResource KpiValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="VIEWS" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_views" Text="0" Style="{StaticResource KpiValue}" Foreground="#E65100"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="LINKS" Style="{StaticResource KpiLabel}"/>
                        <TextBlock x:Name="kpi_links" Text="0" Style="{StaticResource KpiValue}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Files Table -->
            <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="8,8,0,0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,2">
                        <Grid x:Name="grid_header">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="1.1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FileName" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="Health Score" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Size (MB)" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Warnings" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="Un.Materials" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="5" Text="P.E." Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="6" Text="Un.VT" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="7" Text="Links" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="8" Text="Sheets" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="9" Text="Views" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="10" Text="N.Ele" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <StackPanel Grid.Row="1" x:Name="table_body"/>
                </Grid>
            </Border>

            <!-- === SEZIONE 2: HEALTH CHECKS === -->

            <!-- ComboBox + Health Score -->
            <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Model:" Foreground="#666666" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmb_file_select" Grid.Column="1" FontSize="13" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Health Score: " Foreground="#666666" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txt_health_score" Text="0 / 100" Foreground="#333333" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Health Checks Table -->
            <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="8,8,0,0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Check Description" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="Check Passed" Style="{StaticResource TableHeader}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Value" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Score" Style="{StaticResource TableHeader}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <StackPanel Grid.Row="1" x:Name="health_checks_body"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
